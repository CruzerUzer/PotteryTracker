# Server Configuration
PORT=3001
NODE_ENV=development

# Session Configuration
SESSION_SECRET=your-secret-key-change-this-in-production
# Sessions lagras beständigt i en SQLite-fil (sessions.db) som skapas automatiskt
# vid första start. Ändra bara om du vill lägga den någon annanstans (default: database/).
# SESSIONS_DIR=database

# Database Configuration
DB_PATH=database/database.db

# File Upload Configuration
UPLOADS_DIR=uploads
MAX_FILE_SIZE=10485760
IMAGE_MAX_WIDTH=2048
IMAGE_MAX_HEIGHT=2048
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=400
IMAGE_QUALITY=85

# CORS Configuration (comma-separated origins, or 'true' for all)
# REQUIRED in production! Example: CORS_ORIGIN=https://potterytracker.example.com
# 'true' (allow all) is only acceptable for local development.
CORS_ORIGIN=true

# Rate Limiting
# Max API requests per minute per IP (image file serving is exempt)
RATE_LIMIT_MAX=300

# Logging
LOG_LEVEL=debug
